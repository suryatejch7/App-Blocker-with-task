<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="0dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="April 10th"
            android:textSize="12sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/widget_header_middle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0"
            android:alpha="0"
            android:text=""
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/widget_add_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_add_button_background"
            android:contentDescription="Add task"
            android:src="@android:drawable/ic_input_add"
            android:scaleType="fitCenter"
            android:padding="6dp"
            android:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_task_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="9"
        android:layout_marginTop="4dp"
        android:listSelector="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="3dp"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/widget_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="9"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/widget_empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tasks today"
            android:textSize="11sp"
            android:textColor="#B0B0B0"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/widget_empty_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + to add a task"
            android:textSize="10sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
