<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/task_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/task_item_background"
    android:padding="10dp"
    android:minHeight="48dp">

    <!-- Status indicator -->
    <TextView
        android:id="@+id/task_item_status"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:gravity="center"
        android:text="○"
        android:textSize="16sp"
        android:textColor="#FFFFFF" />

    <!-- Task title -->
    <TextView
        android:id="@+id/task_item_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/task_item_status"
        android:layout_marginStart="8dp"
        android:text="Task Title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Task time -->
    <TextView
        android:id="@+id/task_item_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/task_item_status"
        android:layout_below="@id/task_item_title"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        android:text="9:00 AM - 10:00 AM"
        android:textSize="11sp"
        android:textColor="#A0A0A0" />

</RelativeLayout>
